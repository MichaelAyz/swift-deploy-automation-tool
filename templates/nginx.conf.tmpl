
upstream app_backend {
    server app:{{SERVICE_PORT}};
    keepalive 32;
}

log_format swiftdeploy '$time_iso8601 | $status | ${request_time}s | '
                       '$upstream_addr | $request';

server {
    listen {{NGINX_PORT}};
    server_name _;

    access_log /var/log/nginx/access.log swiftdeploy;
    error_log  /var/log/nginx/error.log warn;

    # Timeouts sourced from manifest nginx.proxy_timeout
    proxy_connect_timeout {{PROXY_TIMEOUT}}s;
    proxy_send_timeout    {{PROXY_TIMEOUT}}s;
    proxy_read_timeout    {{PROXY_TIMEOUT}}s;

    # Required header — identifies this stack to downstream consumers
    add_header X-Deployed-By swiftdeploy always;

    location / {
        proxy_pass         http://app_backend;
        proxy_http_version 1.1;

        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   Connection        "";

        # Forward canary mode header from upstream to client
        proxy_pass_header  X-Mode;
    }

    # JSON error bodies for gateway/upstream failures
    error_page 502 = @error502;
    error_page 503 = @error503;
    error_page 504 = @error504;

    location @error502 {
        default_type application/json;
        add_header X-Deployed-By swiftdeploy always;
        return 502 '{"error":"bad gateway","code":502,"service":"{{SERVICE_NAME}}","contact":"ops@swiftdeploy.internal"}';
    }

    location @error503 {
        default_type application/json;
        add_header X-Deployed-By swiftdeploy always;
        return 503 '{"error":"service unavailable","code":503,"service":"{{SERVICE_NAME}}","contact":"ops@swiftdeploy.internal"}';
    }

    location @error504 {
        default_type application/json;
        add_header X-Deployed-By swiftdeploy always;
        return 504 '{"error":"gateway timeout","code":504,"service":"{{SERVICE_NAME}}","contact":"ops@swiftdeploy.internal"}';
    }
}
