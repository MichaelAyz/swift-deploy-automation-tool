services:

  app:
    image: {{SERVICE_IMAGE}}
    container_name: {{SERVICE_NAME}}
    restart: {{RESTART_POLICY}}
    init: true
    environment:
      - MODE={{MODE}}
      - APP_VERSION={{APP_VERSION}}
      - APP_PORT={{SERVICE_PORT}}
    volumes:
      - {{LOG_VOLUME}}:/app/logs
    networks:
      - {{NETWORK_NAME}}
    expose:
      - "{{SERVICE_PORT}}"
    cap_drop:
      - ALL
    cap_add:
      - NET_BIND_SERVICE
    security_opt:
      - no-new-privileges:true
    healthcheck:
      test: ["CMD", "python3", "-c",
             "import urllib.request; urllib.request.urlopen('http://localhost:{{SERVICE_PORT}}/healthz')"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 10s

  nginx:
    image: {{NGINX_IMAGE}}
    container_name: swiftdeploy-nginx
    restart: {{RESTART_POLICY}}
    ports:
      - "{{NGINX_PORT}}:{{NGINX_PORT}}"
    volumes:
      - ./nginx.conf:/etc/nginx/conf.d/default.conf:ro
      - nginx-logs:/var/log/nginx
    networks:
      - {{NETWORK_NAME}}
    cap_drop:
      - ALL
    cap_add:
      - NET_BIND_SERVICE
      - CHOWN
      - SETUID
      - SETGID
    security_opt:
      - no-new-privileges:true
    depends_on:
      app:
        condition: service_healthy

networks:
  {{NETWORK_NAME}}:
    driver: {{NETWORK_DRIVER}}

volumes:
  {{LOG_VOLUME}}:
  nginx-logs: