#!/usr/bin/env python3

import sys
import os
import re
import json
import time
import yaml

# ── Paths ────────────────────────────────────────────────────────────────────
ROOT         = os.path.dirname(os.path.abspath(__file__))
MANIFEST     = os.path.join(ROOT, "manifest.yaml")
TEMPLATES    = os.path.join(ROOT, "templates")
NGINX_TMPL   = os.path.join(TEMPLATES, "nginx.conf.tmpl")
COMPOSE_TMPL = os.path.join(TEMPLATES, "docker-compose.yml.tmpl")
NGINX_OUT    = os.path.join(ROOT, "nginx.conf")
COMPOSE_OUT  = os.path.join(ROOT, "docker-compose.yml")
HISTORY_FILE = os.path.join(ROOT, "history.jsonl")


# ── Helpers ───────────────────────────────────────────────────────────────────
def load_manifest():
    """Parse manifest.yaml and return the data dict."""
    with open(MANIFEST, "r") as f:
        return yaml.safe_load(f)


def render_template(template_path, tokens):
    """
    Read a template file and replace all {{KEY}} placeholders
    with values from the tokens dict.
    Raises an error if any placeholder remains unreplaced after rendering.
    """
    with open(template_path, "r") as f:
        content = f.read()

    for key, value in tokens.items():
        content = content.replace(f"{{{{{key}}}}}", str(value))

    remaining = re.findall(r"\{\{[^}]+\}\}", content)
    if remaining:
        print(f"[error] Unreplaced placeholders in {template_path}: {remaining}")
        sys.exit(1)

    return content


def write_file(path, content):
    """Write content to path, creating directories if needed."""
    os.makedirs(os.path.dirname(path), exist_ok=True)
    with open(path, "w") as f:
        f.write(content)
    print(f"[init] Written: {path}")


def build_tokens(manifest):
    """
    Map every manifest field to its template placeholder name.
    Single place where manifest fields meet template tokens.
    """
    svc = manifest["services"]
    ngx = manifest["nginx"]
    net = manifest["network"]
    opa = manifest["opa"]

    return {
        "SERVICE_NAME":   svc["name"],
        "SERVICE_IMAGE":  svc["image"],
        "SERVICE_PORT":   svc["port"],
        "MODE":           svc["mode"],
        "APP_VERSION":    svc["version"],
        "RESTART_POLICY": svc["restart_policy"],
        "LOG_VOLUME":     svc["log_volume"],
        "NGINX_IMAGE":    ngx["image"],
        "NGINX_PORT":     ngx["port"],
        "PROXY_TIMEOUT":  ngx["proxy_timeout"],
        "NETWORK_NAME":   net["name"],
        "NETWORK_DRIVER": net["driver_type"],
        "OPA_IMAGE":      opa["image"],
        "OPA_PORT":       opa["port"],
    }


# ── OPA helpers ───────────────────────────────────────────────────────────────
def query_opa(opa_port, policy_path, input_data):
    """
    POST input_data to OPA at /v1/data/<policy_path>.
    Returns the parsed 'result' dict on success.

    Three distinct failure modes — each produces a different message:
      1. OPA unreachable  → prints connection error, exits 1
      2. HTTP error       → prints status code, exits 1
      3. Malformed JSON   → prints parse error, exits 1
    """
    import urllib.request
    import urllib.error

    url     = f"http://localhost:{opa_port}/v1/data/{policy_path}"
    payload = json.dumps({"input": input_data}).encode("utf-8")

    try:
        req = urllib.request.Request(
            url,
            data=payload,
            headers={"Content-Type": "application/json"},
            method="POST"
        )
        with urllib.request.urlopen(req, timeout=5) as resp:
            raw = resp.read().decode("utf-8")

    except ConnectionRefusedError:
        print(f"[policy] ERROR: OPA is unreachable at localhost:{opa_port}.")
        print("[policy] Cannot proceed without policy evaluation. Is OPA running?")
        sys.exit(1)
    except urllib.error.URLError as e:
        print(f"[policy] ERROR: Could not connect to OPA — {e.reason}")
        print("[policy] Cannot proceed without policy evaluation.")
        sys.exit(1)
    except Exception as e:
        print(f"[policy] ERROR: Unexpected failure querying OPA — {e}")
        sys.exit(1)

    try:
        body = json.loads(raw)
    except json.JSONDecodeError as e:
        print(f"[policy] ERROR: OPA returned malformed JSON — {e}")
        print(f"[policy] Raw response: {raw[:200]}")
        sys.exit(1)

    if "result" not in body:
        print("[policy] ERROR: OPA response missing 'result' field.")
        print(f"[policy] Full response: {json.dumps(body, indent=2)}")
        sys.exit(1)

    return body["result"]


def get_host_stats():
    """
    Read disk free (GB) and CPU load average from the host.
    disk: uses shutil.disk_usage on ROOT
    cpu:  uses os.getloadavg() — 1-minute load average
    """
    import shutil
    usage        = shutil.disk_usage(ROOT)
    disk_free_gb = usage.free / (1024 ** 3)
    cpu_load     = os.getloadavg()[0]
    return {
        "disk_free_gb": round(disk_free_gb, 2),
        "cpu_load":     round(cpu_load, 4),
    }


def scrape_metrics(nginx_port):
    """
    Fetch /metrics from the app through Nginx and parse:
      - error_rate_pct: percentage of 5xx responses out of total
      - p99_latency_ms: 99th percentile latency in milliseconds

    Prometheus histogram P99 is estimated from buckets using linear
    interpolation — accurate enough for a gate check.

    Returns dict with error_rate_pct and p99_latency_ms.
    Exits with a clear message if /metrics is unreachable.
    """
    import urllib.request
    import urllib.error

    url = f"http://localhost:{nginx_port}/metrics"
    try:
        with urllib.request.urlopen(url, timeout=5) as resp:
            text = resp.read().decode("utf-8")
    except Exception as e:
        print(f"[policy] ERROR: Could not scrape /metrics — {e}")
        print("[policy] Cannot calculate canary health without metrics.")
        sys.exit(1)

    # ── Parse http_requests_total ─────────────────────────────────────────────
    total_requests = 0.0
    error_requests = 0.0

    for line in text.splitlines():
        if line.startswith("http_requests_total{"):
            # Extract status_code label value
            m_status = re.search(r'status_code="(\d+)"', line)
            m_value  = re.search(r"\}\s+([\d.eE+\-]+)$", line)
            if m_status and m_value:
                code  = int(m_status.group(1))
                count = float(m_value.group(1))
                total_requests += count
                if code >= 500:
                    error_requests += count

    error_rate_pct = (error_requests / total_requests * 100) if total_requests > 0 else 0.0

    # ── Parse histogram buckets for P99 ──────────────────────────────────────
    # Collect bucket counts: {le_value: cumulative_count}
    buckets = {}
    total_count = 0.0

    for line in text.splitlines():
        if line.startswith("http_request_duration_seconds_bucket{"):
            m_le    = re.search(r'le="([^"]+)"', line)
            m_value = re.search(r"\}\s+([\d.eE+\-]+)$", line)
            if m_le and m_value:
                le_str = m_le.group(1)
                count  = float(m_value.group(1))
                if le_str == "+Inf":
                    total_count = count
                else:
                    buckets[float(le_str)] = count

    # Linear interpolation to estimate P99
    p99_latency_ms = 0.0
    if total_count > 0:
        target = 0.99 * total_count
        sorted_les = sorted(buckets.keys())

        prev_le    = 0.0
        prev_count = 0.0

        for le in sorted_les:
            count = buckets[le]
            if count >= target:
                # Interpolate within this bucket
                if count > prev_count:
                    fraction = (target - prev_count) / (count - prev_count)
                    p99_sec  = prev_le + fraction * (le - prev_le)
                else:
                    p99_sec = le
                p99_latency_ms = round(p99_sec * 1000, 2)
                break
            prev_le    = le
            prev_count = count
        else:
            # All requests in +Inf bucket — use last known bucket upper bound
            p99_latency_ms = round(sorted_les[-1] * 1000, 2) if sorted_les else 0.0

    return {
        "error_rate_pct": round(error_rate_pct, 4),
        "p99_latency_ms": round(p99_latency_ms, 2),
    }


def enforce_policy(result, domain):
    """
    Given an OPA result dict, print the outcome and exit if denied.
    domain is a label string like 'infra' or 'canary' for log prefixes.
    """
    allowed    = result.get("allow", False)
    summary    = result.get("summary", "no summary returned")
    violations = result.get("violations", [])

    if allowed:
        print(f"[policy:{domain}] ✓ {summary}")
    else:
        print(f"[policy:{domain}] ✗ BLOCKED — {summary}")
        for v in violations:
            print(f"[policy:{domain}]   • {v}")
        sys.exit(1)


def append_history(event):
    """
    Append a single event dict to history.jsonl.
    Each line is a self-contained JSON object — one per scrape or event.
    """
    event["timestamp"] = time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime())
    with open(HISTORY_FILE, "a") as f:
        f.write(json.dumps(event) + "\n")


# ── Subcommands ───────────────────────────────────────────────────────────────
def cmd_init():
    """
    Parse manifest.yaml → render templates → write generated files.
    Pure: no Docker calls, no side effects beyond writing two files.
    """
    print("[init] Loading manifest...")
    manifest = load_manifest()

    print("[init] Building token map...")
    tokens = build_tokens(manifest)

    print("[init] Rendering nginx.conf...")
    nginx_content = render_template(NGINX_TMPL, tokens)
    write_file(NGINX_OUT, nginx_content)

    print("[init] Rendering docker-compose.yml...")
    compose_content = render_template(COMPOSE_TMPL, tokens)
    write_file(COMPOSE_OUT, compose_content)

    print("[init] Done. Generated files are in ./")


def cmd_validate():
    """
    Run pre-flight checks before any deployment.
    Prints PASS/FAIL for each check. Exits non-zero on first failure.
    """
    results = []
    failed  = False

    def check(label, passed, detail=""):
        nonlocal failed
        status = "PASS" if passed else "FAIL"
        line   = f"  [{status}] {label}"
        if detail:
            line += f" — {detail}"
        print(line)
        results.append(passed)
        if not passed:
            failed = True

    print("\n[validate] Running pre-flight checks...\n")

    # ── Check 1: manifest.yaml exists and is valid YAML ──────────────────────
    manifest = None
    try:
        with open(MANIFEST, "r") as f:
            manifest = yaml.safe_load(f)
        check("manifest.yaml exists and is valid YAML", True)
    except FileNotFoundError:
        check("manifest.yaml exists and is valid YAML", False, "file not found")
        print("\n[validate] Cannot continue without manifest. Aborting.")
        sys.exit(1)
    except yaml.YAMLError as e:
        check("manifest.yaml exists and is valid YAML", False, f"parse error: {e}")
        print("\n[validate] Cannot continue with invalid YAML. Aborting.")
        sys.exit(1)

    # ── Check 2: All required fields present and non-empty ───────────────────
    required_fields = {
        "services.name":           ["services", "name"],
        "services.image":          ["services", "image"],
        "services.port":           ["services", "port"],
        "services.mode":           ["services", "mode"],
        "services.version":        ["services", "version"],
        "services.restart_policy": ["services", "restart_policy"],
        "services.log_volume":     ["services", "log_volume"],
        "nginx.image":             ["nginx", "image"],
        "nginx.port":              ["nginx", "port"],
        "nginx.proxy_timeout":     ["nginx", "proxy_timeout"],
        "network.name":            ["network", "name"],
        "network.driver_type":     ["network", "driver_type"],
        "opa.image":               ["opa", "image"],
        "opa.port":                ["opa", "port"],
    }

    missing = []
    for field_name, path in required_fields.items():
        try:
            value = manifest
            for key in path:
                value = value[key]
            if value is None or str(value).strip() == "":
                missing.append(field_name)
        except (KeyError, TypeError):
            missing.append(field_name)

    if missing:
        check("All required fields present and non-empty", False,
              f"missing: {', '.join(missing)}")
    else:
        check("All required fields present and non-empty", True)

    # ── Check 3: Docker image exists locally ─────────────────────────────────
    import subprocess
    image = manifest.get("services", {}).get("image", "")
    try:
        result = subprocess.run(
            ["docker", "image", "inspect", image],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL
        )
        if result.returncode == 0:
            check(f"Docker image '{image}' exists locally", True)
        else:
            check(f"Docker image '{image}' exists locally", False,
                  "run: docker build -t swift-deploy-1-node:latest .")
    except FileNotFoundError:
        check(f"Docker image '{image}' exists locally", False,
              "docker not found on PATH")

    # ── Check 4: Nginx port is not already bound ──────────────────────────────
    import socket
    nginx_port = int(manifest.get("nginx", {}).get("port", 8080))
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    try:
        sock.bind(("0.0.0.0", nginx_port))
        sock.close()
        check(f"Nginx port {nginx_port} is free on host", True)
    except OSError:
        check(f"Nginx port {nginx_port} is free on host", False,
              f"port {nginx_port} already in use")

    # ── Check 5: Generated nginx.conf is structurally valid ──────────────────
    if not os.path.exists(NGINX_OUT):
        check("nginx.conf syntax is valid", False,
              "nginx.conf not found — run ./swiftdeploy init first")
    else:
        nginx_errors = []
        with open(NGINX_OUT, "r") as f:
            nginx_content = f.read()

        remaining = re.findall(r"\{\{[^}]+\}\}", nginx_content)
        if remaining:
            nginx_errors.append(f"unreplaced placeholders: {remaining}")

        required_directives = [
            "listen ",
            "proxy_pass ",
            "access_log ",
            "error_log ",
            "proxy_connect_timeout ",
            "add_header X-Deployed-By",
            "error_page 502",
            "error_page 503",
            "error_page 504",
        ]
        for directive in required_directives:
            if directive not in nginx_content:
                nginx_errors.append(f"missing directive: '{directive}'")

        open_braces  = nginx_content.count("{")
        close_braces = nginx_content.count("}")
        if open_braces != close_braces:
            nginx_errors.append(
                f"unbalanced braces: {open_braces} open, {close_braces} close"
            )

        if nginx_errors:
            check("nginx.conf syntax is valid", False, "; ".join(nginx_errors))
        else:
            check("nginx.conf syntax is valid", True)

    # ── Summary ───────────────────────────────────────────────────────────────
    total  = len(results)
    passed = sum(results)
    print(f"\n[validate] {passed}/{total} checks passed.\n")

    if failed:
        sys.exit(1)


def cmd_deploy():
    """
    Full deployment lifecycle:
    0. Run init to generate configs
    1. Bring up OPA and query infra policy — block if host doesn't meet requirements
    2. Bring up the stack with docker compose
    3. Poll /healthz through Nginx until healthy or 60s timeout
    """
    import subprocess
    import time
    import urllib.request
    import urllib.error

    print("[deploy] Starting deployment...\n")

    # Step 0: Generate configs from manifest
    print("[deploy] Step 0/3 — Generating configs...")
    cmd_init()
    print()

    # Step 1: OPA infra policy gate
    print("[deploy] Step 1/3 — Checking infrastructure policy...")
    manifest   = load_manifest()
    opa_port   = manifest["opa"]["port"]
    
    subprocess.run(
        ["docker", "compose", "-f", COMPOSE_OUT, "up", "-d", "opa"],
        cwd=ROOT,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL
    )
    time.sleep(2)
    
    host_stats = get_host_stats()

    print(f"[deploy]   disk_free: {host_stats['disk_free_gb']}GB  "
          f"cpu_load: {host_stats['cpu_load']}")

    try:
        result = query_opa(opa_port, "infra/decision", host_stats)
        enforce_policy(result, "infra")
    except SystemExit as e:
        subprocess.run(
            ["docker", "compose", "-f", COMPOSE_OUT, "stop", "opa"],
            cwd=ROOT,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL
        )
        sys.exit(e.code)
        
    print()

    # Step 2: Bring up the stack
    print("[deploy] Step 2/3 — Bringing up stack...")
    result = subprocess.run(
        ["docker", "compose", "-f", COMPOSE_OUT, "up", "-d", "--remove-orphans"],
        cwd=ROOT
    )
    if result.returncode != 0:
        print("[deploy] ERROR: docker compose up failed.")
        sys.exit(1)
    print()

    # Step 3: Poll /healthz through Nginx
    print("[deploy] Step 3/3 — Waiting for stack to become healthy...")
    nginx_port = manifest["nginx"]["port"]
    health_url = f"http://localhost:{nginx_port}/healthz"
    timeout    = 60
    interval   = 3
    elapsed    = 0
    healthy    = False

    while elapsed < timeout:
        try:
            with urllib.request.urlopen(health_url, timeout=3) as resp:
                if resp.status == 200:
                    print(f"[deploy] Health check passed after {elapsed}s ✓")
                    healthy = True
                    break
        except Exception:
            pass
        print(f"[deploy] Waiting... ({elapsed}s elapsed)")
        time.sleep(interval)
        elapsed += interval

    if not healthy:
        print(f"[deploy] ERROR: Stack did not become healthy within {timeout}s.")
        print("[deploy] Check logs with: docker compose -f docker-compose.yml logs")
        sys.exit(1)

    # Record deploy event in history
    append_history({
        "event":    "deploy",
        "mode":     manifest["services"]["mode"],
        "version":  manifest["services"]["version"],
        "host":     host_stats,
    })

    print()
    print("[deploy] Stack is up and healthy.")
    print(f"[deploy] Service available at http://localhost:{nginx_port}/")
    print(f"[deploy] Health endpoint:       http://localhost:{nginx_port}/healthz")
    print()


def cmd_promote(args):
    """
    Switch deployment mode between canary and stable.
    0. Query OPA canary policy (only when promoting TO canary) — scrapes /metrics
    1. Updates mode field in manifest.yaml in-place
    2. Regenerates docker-compose.yml with new MODE env var
    3. Restarts the app container only — nginx stays running
    4. Confirms new mode via /healthz and /
    """
    import subprocess
    import urllib.request
    import urllib.error

    valid_modes = ["canary", "stable"]
    if not args or args[0] not in valid_modes:
        print(f"[promote] ERROR: Must specify a mode: {valid_modes}")
        print("  Usage: ./swiftdeploy promote [canary|stable]")
        sys.exit(1)

    target_mode = args[0]

    manifest     = load_manifest()
    current_mode = manifest["services"]["mode"]

    if current_mode == target_mode:
        print(f"[promote] Already in {target_mode} mode. Nothing to do.")
        sys.exit(0)

    print(f"[promote] Promoting {current_mode} → {target_mode}...\n")

    # Step 0: OPA canary policy gate (only when promoting canary → stable,
    # i.e. graduating a canary — verify it's healthy before making it stable)
    if target_mode == "stable" and current_mode == "canary":
        print("[promote] Step 0/4 — Checking canary safety policy...")
        opa_port   = manifest["opa"]["port"]
        nginx_port = manifest["nginx"]["port"]

        metrics = scrape_metrics(nginx_port)
        print(f"[promote]   error_rate: {metrics['error_rate_pct']}%  "
              f"p99_latency: {metrics['p99_latency_ms']}ms")

        result = query_opa(opa_port, "canary/decision", metrics)
        enforce_policy(result, "canary")

        # Record policy check in history
        append_history({
            "event":   "pre_promote_policy_check",
            "from":    current_mode,
            "to":      target_mode,
            "metrics": metrics,
            "allowed": result.get("allow", False),
        })
        print()

    # Step 1: Update manifest.yaml in-place
    print(f"[promote] Step 1/4 — Updating manifest.yaml mode: {target_mode}")
    with open(MANIFEST, "r") as f:
        raw = f.read()

    updated = re.sub(
        r"^(\s*mode:\s*)(\S+)$",
        lambda m: f"{m.group(1)}{target_mode}",
        raw,
        flags=re.MULTILINE
    )

    if updated == raw:
        print("[promote] ERROR: Could not find mode field in manifest.yaml")
        sys.exit(1)

    with open(MANIFEST, "w") as f:
        f.write(updated)

    verified = load_manifest()
    if verified["services"]["mode"] != target_mode:
        print("[promote] ERROR: manifest.yaml update failed verification")
        sys.exit(1)

    print(f"[promote] manifest.yaml updated ✓")

    # Step 2: Regenerate docker-compose.yml
    print(f"[promote] Step 2/4 — Regenerating docker-compose.yml...")
    cmd_init()

    # Step 3: Restart app container only
    print(f"\n[promote] Step 3/4 — Restarting app container...")
    result = subprocess.run(
        ["docker", "compose", "-f", COMPOSE_OUT,
         "up", "-d", "--no-deps", "--force-recreate", "app"],
        cwd=ROOT
    )
    if result.returncode != 0:
        print("[promote] ERROR: Failed to restart app container.")
        sys.exit(1)
    print("[promote] App container restarted ✓")

    # Step 4: Confirm new mode
    print(f"\n[promote] Step 4/4 — Confirming new mode is active...")
    manifest   = load_manifest()
    nginx_port = manifest["nginx"]["port"]
    health_url = f"http://localhost:{nginx_port}/healthz"
    root_url   = f"http://localhost:{nginx_port}/"
    timeout    = 30
    interval   = 2
    elapsed    = 0
    confirmed  = False

    while elapsed < timeout:
        try:
            with urllib.request.urlopen(health_url, timeout=3) as resp:
                if resp.status == 200:
                    confirmed = True
                    break
        except Exception:
            pass
        print(f"[promote] Waiting for app to come back... ({elapsed}s)")
        time.sleep(interval)
        elapsed += interval

    if not confirmed:
        print("[promote] ERROR: App did not respond within 30s after restart.")
        sys.exit(1)

    try:
        with urllib.request.urlopen(root_url, timeout=5) as resp:
            body      = json.loads(resp.read().decode())
            live_mode = body.get("mode", "unknown")
    except Exception:
        live_mode = "unknown"

    print(f"[promote] /healthz responded ✓")
    print(f"[promote] Live mode confirmed: {live_mode}")

    if live_mode != target_mode:
        print(f"[promote] WARNING: Expected {target_mode}, got {live_mode}")
        sys.exit(1)

    # Record promotion event in history
    append_history({
        "event": "promote",
        "from":  current_mode,
        "to":    target_mode,
    })

    print(f"\n[promote] Promotion complete: {current_mode} → {target_mode} ✓")


def cmd_teardown(args):
    """
    Stop and remove all containers, networks, and volumes.
    --clean also deletes generated config files.
    """
    import subprocess

    clean        = "--clean" in args
    compose_file = COMPOSE_OUT

    print("[teardown] Stopping stack...")

    if not os.path.exists(compose_file):
        print("[teardown] WARNING: docker-compose.yml not found.")
        print("[teardown] Attempting teardown by container name directly...")

        for name in ["swiftdeploy-nginx", "swiftdeploy-opa", "app"]:
            subprocess.run(
                ["docker", "rm", "-f", name],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL
            )
        subprocess.run(
            ["docker", "network", "rm", "swiftdeploy-net"],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL
        )
        print("[teardown] Containers and network removed.")

    else:
        result = subprocess.run(
            ["docker", "compose", "-f", compose_file,
             "down", "--volumes", "--remove-orphans"],
            cwd=ROOT
        )
        if result.returncode != 0:
            print("[teardown] WARNING: docker compose down reported errors.")
        else:
            print("[teardown] Containers, networks, and volumes removed.")

    if clean:
        print("[teardown] --clean flag set. Removing generated configs...")
        for path in [NGINX_OUT, COMPOSE_OUT]:
            if os.path.exists(path):
                os.remove(path)
                print(f"[teardown] Deleted: {path}")
            else:
                print(f"[teardown] Already gone: {path}")
        print("[teardown] Clean complete.")

    print("[teardown] Done.")


def cmd_status():
    """
    Live-refreshing terminal dashboard.
    Scrapes /metrics every 5s, calculates req/s and P99 latency,
    shows policy compliance, and appends each scrape to history.jsonl.
    Press Ctrl+C to exit.
    """
    import urllib.request
    import urllib.error

    manifest   = load_manifest()
    nginx_port = manifest["nginx"]["port"]
    opa_port   = manifest["opa"]["port"]

    print("[status] Starting live dashboard. Press Ctrl+C to stop.\n")

    prev_total    = 0.0
    prev_time     = time.time()
    scrape_number = 0

    try:
        while True:
            scrape_number += 1
            now       = time.time()
            timestamp = time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime())

            # ── Scrape /metrics ───────────────────────────────────────────────
            metrics_url = f"http://localhost:{nginx_port}/metrics"
            try:
                with urllib.request.urlopen(metrics_url, timeout=5) as resp:
                    metrics_text = resp.read().decode("utf-8")
                metrics_ok = True
            except Exception as e:
                metrics_ok    = False
                metrics_text  = ""
                metrics_error = str(e)

            if not metrics_ok:
                print(f"[{timestamp}] scrape #{scrape_number}")
                print(f"  [WARN] /metrics unreachable — {metrics_error}")
                time.sleep(5)
                continue

            # ── Parse totals ──────────────────────────────────────────────────
            total_requests = 0.0
            error_requests = 0.0

            for line in metrics_text.splitlines():
                if line.startswith("http_requests_total{"):
                    m_status = re.search(r'status_code="(\d+)"', line)
                    m_value  = re.search(r"\}\s+([\d.eE+\-]+)$", line)
                    if m_status and m_value:
                        code  = int(m_status.group(1))
                        count = float(m_value.group(1))
                        total_requests += count
                        if code >= 500:
                            error_requests += count

            elapsed       = now - prev_time
            delta         = total_requests - prev_total
            req_per_sec   = round(delta / elapsed, 2) if elapsed > 0 else 0.0
            error_rate    = round((error_requests / total_requests * 100), 4) if total_requests > 0 else 0.0

            # ── Parse uptime, mode, chaos gauges ─────────────────────────────
            uptime     = 0.0
            app_mode   = 0
            chaos_val  = 0

            for line in metrics_text.splitlines():
                if line.startswith("app_uptime_seconds "):
                    try: uptime = float(line.split()[-1])
                    except: pass
                elif line.startswith("app_mode "):
                    try: app_mode = int(float(line.split()[-1]))
                    except: pass
                elif line.startswith("chaos_active "):
                    try: chaos_val = int(float(line.split()[-1]))
                    except: pass

            mode_str  = "canary" if app_mode == 1 else "stable"
            chaos_str = {0: "none", 1: "slow", 2: "error"}.get(chaos_val, "unknown")

            # ── Parse P99 latency ─────────────────────────────────────────────
            buckets     = {}
            total_count = 0.0

            for line in metrics_text.splitlines():
                if line.startswith("http_request_duration_seconds_bucket{"):
                    m_le    = re.search(r'le="([^"]+)"', line)
                    m_value = re.search(r"\}\s+([\d.eE+\-]+)$", line)
                    if m_le and m_value:
                        le_str = m_le.group(1)
                        count  = float(m_value.group(1))
                        if le_str == "+Inf":
                            total_count = count
                        else:
                            buckets[float(le_str)] = count

            p99_ms = 0.0
            if total_count > 0:
                target     = 0.99 * total_count
                sorted_les = sorted(buckets.keys())
                prev_le    = 0.0
                prev_count = 0.0
                for le in sorted_les:
                    count = buckets[le]
                    if count >= target:
                        if count > prev_count:
                            fraction = (target - prev_count) / (count - prev_count)
                            p99_ms   = round((prev_le + fraction * (le - prev_le)) * 1000, 2)
                        else:
                            p99_ms = round(le * 1000, 2)
                        break
                    prev_le    = le
                    prev_count = count

            # ── Policy compliance check ───────────────────────────────────────
            host_stats     = get_host_stats()
            infra_result   = None
            canary_result  = None
            policy_error   = None

            try:
                infra_result  = query_opa(opa_port, "infra/decision",
                                          host_stats)
                canary_result = query_opa(opa_port, "canary/decision",
                                          {"error_rate_pct": error_rate,
                                           "p99_latency_ms": p99_ms})
            except SystemExit:
                policy_error = "OPA unreachable"

            # ── Print dashboard ───────────────────────────────────────────────
            print(f"┌─ SwiftDeploy Status — {timestamp} (scrape #{scrape_number})")
            print(f"│  Mode: {mode_str:<10}  Uptime: {int(uptime)}s  "
                  f"Chaos: {chaos_str}")
            print(f"│  Throughput: {req_per_sec} req/s  "
                  f"Errors: {error_rate}%  P99: {p99_ms}ms")
            print("│")
            print("│  Policy Compliance:")

            if policy_error:
                print(f"│    [WARN] {policy_error}")
            else:
                infra_ok   = infra_result.get("allow", False) if infra_result else False
                canary_ok  = canary_result.get("allow", False) if canary_result else False
                infra_sym  = "✓" if infra_ok  else "✗"
                canary_sym = "✓" if canary_ok else "✗"
                print(f"│    [{infra_sym}] infra   — "
                      f"{infra_result.get('summary', 'n/a')}")
                print(f"│    [{canary_sym}] canary  — "
                      f"{canary_result.get('summary', 'n/a')}")

                if not infra_ok and infra_result:
                    for v in infra_result.get("violations", []):
                        print(f"│         • {v}")
                if not canary_ok and canary_result:
                    for v in canary_result.get("violations", []):
                        print(f"│         • {v}")

            print("└─────────────────────────────────────────────────────")

            # ── Append to history.jsonl ───────────────────────────────────────
            append_history({
                "event":          "status_scrape",
                "mode":           mode_str,
                "chaos":          chaos_str,
                "uptime_seconds": uptime,
                "req_per_sec":    req_per_sec,
                "error_rate_pct": error_rate,
                "p99_latency_ms": p99_ms,
                "total_requests": total_requests,
                "infra_allow":    infra_result.get("allow") if infra_result else None,
                "canary_allow":   canary_result.get("allow") if canary_result else None,
                "infra_violations":  infra_result.get("violations", []) if infra_result else [],
                "canary_violations": canary_result.get("violations", []) if canary_result else [],
            })

            prev_total = total_requests
            prev_time  = now

            time.sleep(5)

    except KeyboardInterrupt:
        print("\n[status] Dashboard stopped.")


def cmd_audit():
    """
    Parse history.jsonl and generate audit_report.md.
    Sections:
      1. Timeline — mode changes and chaos injections
      2. Violations — any policy check that failed
    """
    if not os.path.exists(HISTORY_FILE):
        print("[audit] No history.jsonl found. Run 'status' first to generate data.")
        sys.exit(1)

    events = []
    with open(HISTORY_FILE, "r") as f:
        for line_num, line in enumerate(f, 1):
            line = line.strip()
            if not line:
                continue
            try:
                events.append(json.loads(line))
            except json.JSONDecodeError as e:
                print(f"[audit] WARNING: Skipping malformed line {line_num} — {e}")

    if not events:
        print("[audit] history.jsonl is empty. Nothing to report.")
        sys.exit(0)

    # ── Build timeline ────────────────────────────────────────────────────────
    timeline_rows = []
    for e in events:
        ts  = e.get("timestamp", "unknown")
        evt = e.get("event", "unknown")

        if evt == "deploy":
            timeline_rows.append((
                ts, "deploy",
                f"Deployed version {e.get('version','?')} "
                f"in {e.get('mode','?')} mode"
            ))
        elif evt == "promote":
            timeline_rows.append((
                ts, "promote",
                f"Mode changed: {e.get('from','?')} → {e.get('to','?')}"
            ))
        elif evt == "pre_promote_policy_check":
            allowed = e.get("allowed", False)
            status  = "ALLOWED" if allowed else "BLOCKED"
            timeline_rows.append((
                ts, "policy_check",
                f"Pre-promote policy check {status} "
                f"({e.get('from','?')} → {e.get('to','?')})"
            ))
        elif evt == "status_scrape":
            chaos = e.get("chaos", "none")
            if chaos != "none":
                timeline_rows.append((
                    ts, "chaos_detected",
                    f"Chaos active: {chaos} | "
                    f"error_rate={e.get('error_rate_pct','?')}% "
                    f"p99={e.get('p99_latency_ms','?')}ms"
                ))

    # ── Build violations ──────────────────────────────────────────────────────
    violation_rows = []
    for e in events:
        ts  = e.get("timestamp", "unknown")
        evt = e.get("event", "unknown")

        if evt == "status_scrape":
            iv = e.get("infra_violations", [])
            cv = e.get("canary_violations", [])
            for v in iv:
                violation_rows.append((ts, "infra", v))
            for v in cv:
                violation_rows.append((ts, "canary", v))

        elif evt == "pre_promote_policy_check" and not e.get("allowed", True):
            m = e.get("metrics", {})
            violation_rows.append((
                ts, "canary",
                f"Pre-promote blocked — "
                f"error_rate={m.get('error_rate_pct','?')}% "
                f"p99={m.get('p99_latency_ms','?')}ms"
            ))

    # ── Render markdown ───────────────────────────────────────────────────────
    lines = []
    lines.append("# SwiftDeploy Audit Report")
    lines.append("")
    lines.append(f"Generated: {time.strftime('%Y-%m-%dT%H:%M:%SZ', time.gmtime())}")
    lines.append(f"Events parsed: {len(events)}")
    lines.append("")

    # Timeline section
    lines.append("## Timeline")
    lines.append("")
    if timeline_rows:
        lines.append("| Timestamp | Event | Detail |")
        lines.append("|-----------|-------|--------|")
        for ts, evt, detail in timeline_rows:
            lines.append(f"| `{ts}` | {evt} | {detail} |")
    else:
        lines.append("_No significant events recorded._")
    lines.append("")

    # Violations section
    lines.append("## Policy Violations")
    lines.append("")
    if violation_rows:
        lines.append("| Timestamp | Domain | Violation |")
        lines.append("|-----------|--------|-----------|")
        for ts, domain, violation in violation_rows:
            lines.append(f"| `{ts}` | {domain} | {violation} |")
    else:
        lines.append("_No policy violations recorded._")
    lines.append("")

    # Summary counts
    lines.append("## Summary")
    lines.append("")
    lines.append(f"- Total events: {len(events)}")
    lines.append(f"- Timeline entries: {len(timeline_rows)}")
    lines.append(f"- Policy violations: {len(violation_rows)}")
    lines.append("")

    report_path = os.path.join(ROOT, "audit_report.md")
    with open(report_path, "w") as f:
        f.write("\n".join(lines))

    print(f"[audit] Report written to {report_path}")
    print(f"[audit] {len(timeline_rows)} timeline entries, "
          f"{len(violation_rows)} violations.")


def usage():
    print("""
Usage: ./swiftdeploy <subcommand> [options]

Subcommands:
  init                     Generate nginx.conf and docker-compose.yml from manifest
  validate                 Run pre-flight checks
  deploy                   Init + bring up stack + wait for health (OPA gated)
  promote [canary|stable]  Switch deployment mode (OPA gated on canary→stable)
  teardown [--clean]       Stop stack and remove containers/volumes
  status                   Live metrics dashboard — writes to history.jsonl
  audit                    Generate audit_report.md from history.jsonl
""")


# ── Entry point ───────────────────────────────────────────────────────────────
if __name__ == "__main__":
    if len(sys.argv) < 2:
        usage()
        sys.exit(1)

    subcommand = sys.argv[1]

    if subcommand == "init":
        cmd_init()
    elif subcommand == "validate":
        cmd_validate()
    elif subcommand == "deploy":
        cmd_deploy()
    elif subcommand == "promote":
        cmd_promote(sys.argv[2:])
    elif subcommand == "teardown":
        cmd_teardown(sys.argv[2:])
    elif subcommand == "status":
        cmd_status()
    elif subcommand == "audit":
        cmd_audit()
    else:
        print(f"[error] Unknown subcommand: {subcommand}")
        usage()
        sys.exit(1)
